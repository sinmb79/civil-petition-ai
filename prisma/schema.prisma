generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  petitions           Petition[]
  draftReplies        DraftReply[]
  auditFindings       AuditFinding[]
  auditCorpusDocs     AuditCorpusDocument[]
  auditCases          AuditCase[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles  UserRole[]

  @@index([tenantId])
  @@map("users")
}

model Role {
  id        String   @id @default(uuid())
  name      RoleName @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Petition {
  id        String   @id @default(uuid())
  title     String
  content   String
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  draftReply  DraftReply?
  auditCases  AuditCase[]

  @@index([tenantId])
  @@map("petitions")
}

model DraftReply {
  id         String   @id @default(uuid())
  petitionId String   @unique @map("petition_id")
  body       String
  tenantId   String   @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("draft_replies")
}

model AuditFinding {
  id         String   @id @default(uuid())
  title      String
  details    String
  tenantId   String   @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("audit_findings")
}

model AuditCorpusDocument {
  id         String   @id @default(uuid())
  title      String
  body       String
  tenantId   String   @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("audit_corpus_documents")
}

model AuditCase {
  id         String   @id @default(uuid())
  petitionId String?  @map("petition_id")
  summary    String
  tenantId   String   @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  petition Petition? @relation(fields: [petitionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("audit_cases")
}

enum RoleName {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}
