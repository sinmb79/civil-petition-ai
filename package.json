{
  "name": "civil-petition-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm prisma:generate",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "pnpm test:jest && pnpm test:node",
    "test:jest": "jest --runInBand",
    "test:node": "node --test tests/auditRiskEngine.test.mjs tests/export.test.mjs",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate --schema=database/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=database/schema.prisma",
    "prisma:seed": "tsx database/seed.ts",
    "db:push:test": "prisma db push --schema=database/schema.test.prisma",
    "prisma:generate:test": "prisma generate --schema=database/schema.test.prisma",
    "cleanup:jobs": "tsx scripts/cleanup.ts",
    "worker:start": "tsx scripts/worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "schema": "database/schema.prisma"
  }
}
